{
	"name": "potber-auth",
	"version": "1.6.0",
	"private": true,
	"description": "An authentication service for forum.mods.de based on OAuth using potber-api.",
	"repository": "https://github.com/potber/potber-auth",
	"license": "GPL-3.0-only",
	"author": "https://github.com/spuxx-dev",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"start": "vite dev",
		"dev": "vite dev",
		"host": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"serve-tests": "vite build --mode test && ORIGIN=http://localhost:4173 node tests/server.js",
		"test": "npm run test:ui",
		"test:ui": "playwright test",
		"lint": "prettier --check . && eslint . && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fortawesome/free-brands-svg-icons": "^7.2.0",
		"@fortawesome/free-regular-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.54.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"express": "^5.2.1",
		"msw": "^2.12.10",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.10",
		"svelte-check": "^4.4.5",
		"svelte-fa": "^4.0.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"type": "module"
}
